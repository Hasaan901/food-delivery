# Copy this file to .env and fill in your own values
# cp .env.example .env

SECRET_KEY=your-django-secret-key-here

# Set to True for local development, False for production
DEBUG=True

# Comma-separated list of allowed hosts (leave default for local dev)
# ALLOWED_HOSTS=127.0.0.1,localhost,.vercel.app

# Email (Gmail SMTP) — use an App Password, not your real password
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_HOST_USER=your_gmail@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password
ORDER_CONFIRMATION_EMAIL=your_email@example.com

# PostgreSQL database URL (required for Vercel production)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Get a free DB from: https://supabase.com or https://neon.tech
# DATABASE_URL=postgres://user:password@host:5432/dbname
